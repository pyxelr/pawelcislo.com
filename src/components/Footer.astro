---
import EditLink from 'virtual:starlight/components/EditLink';
import Pagination from 'virtual:starlight/components/Pagination';
import config from 'virtual:starlight/user-config';
import { Icon } from '@astrojs/starlight/components';

const currentYear = new Date().getFullYear();
const startYear = 2018;
const yearRange = currentYear > startYear ? `${startYear} – ${currentYear}` : startYear;

const { lang, lastUpdated, entry } = Astro.locals.starlightRoute;
const slug = entry?.id ?? '';
const filePath = entry?.filePath;
const historyUrl = filePath
	? `https://github.com/pyxelr/pawelcislo.com/commits/main/${filePath}`
	: undefined;

// Schema.org structured data
const isPost = slug.startsWith('posts/');
const isHome = slug === '' || slug === 'index';
const siteUrl = 'https://pawelcislo.com';

const personSchema = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: 'Paweł Cisło',
	url: siteUrl,
	jobTitle: 'MLOps Engineer',
	sameAs: [
		'https://github.com/pyxelr',
		'https://x.com/pawel_cislo',
		'https://www.linkedin.com/in/pawelcislo/',
		'https://www.facebook.com/pawelcislocom/',
		'https://www.instagram.com/pawel_cislo/',
		'https://goodreads.com/pyxelr/',
		'https://hypothes.is/users/pyxelr',
		'https://soundcloud.com/pyxelr',
	],
};

const postDate = isPost && entry?.data?.date ? new Date(entry.data.date) : null;
const articleSchema = isPost ? {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: entry?.data?.title,
	url: `${siteUrl}/${slug}/`,
	...(postDate && { datePublished: postDate.toISOString().split('T')[0] }),
	...(lastUpdated && { dateModified: lastUpdated.toISOString().split('T')[0] }),
	author: {
		'@type': 'Person',
		name: 'Paweł Cisło',
		url: siteUrl,
	},
	publisher: {
		'@type': 'Person',
		name: 'Paweł Cisło',
		url: siteUrl,
	},
} : null;
---

<footer class="sl-flex">
	{entry.data.discuss && entry.data.discuss.length > 0 && (
		<div class="discuss-on">
			<span>Discuss on</span>
			{entry.data.discuss.map((d, i) => (
				<><a href={d.url} target="_blank" rel="noopener noreferrer">{d.platform}</a>{i < entry.data.discuss!.length - 1 && <span class="sep"> · </span>}</>
			))}
		</div>
	)}
	<div class="meta sl-flex">
		<EditLink />
		{lastUpdated && (
			<p>
				{Astro.locals.t('page.lastUpdated')}{' '}
				{historyUrl ? (
					<a href={historyUrl} target="_blank" rel="noopener noreferrer">
						<time datetime={lastUpdated.toISOString()}>
							{lastUpdated.toLocaleDateString(lang, { dateStyle: 'medium', timeZone: 'UTC' })}
						</time>
					</a>
				) : (
					<time datetime={lastUpdated.toISOString()}>
						{lastUpdated.toLocaleDateString(lang, { dateStyle: 'medium', timeZone: 'UTC' })}
					</time>
				)}
			</p>
		)}
	</div>
	<Pagination />

	<div class="site-footer">
		{config.credits && (
			<a class="kudos sl-flex" href="https://starlight.astro.build">
				<Icon name="starlight" /> {Astro.locals.t('builtWithStarlight.label')}
			</a>
		)}
		<p class="copyright">
			© {yearRange} Paweł Cisło
		</p>
		<p class="links">
			<a href="https://pawelcislo.substack.com" target="_blank" rel="noopener noreferrer">Newsletter</a> | <a href="/rss.xml">RSS Feed</a> | <a href="https://ko-fi.com/pawelcislo" target="_blank" rel="noopener noreferrer">Support</a>
		</p>
	</div>
</footer>

{isHome && (
	<script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />
)}
{articleSchema && (
	<script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
)}

<style>
	footer {
		flex-direction: column;
		gap: 1.5rem;
	}
	.discuss-on {
		margin-top: 3rem;
		padding: 0.75rem 1rem;
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.5rem;
		font-size: var(--sl-text-sm);
		color: var(--sl-color-gray-3);
		text-align: center;
	}
	.discuss-on span:first-child {
		margin-right: 0.5rem;
	}
	.discuss-on a {
		color: var(--sl-color-accent-high);
		text-decoration: underline;
	}
	.discuss-on a:hover {
		color: var(--sl-color-white);
	}
	.discuss-on .sep {
		color: var(--sl-color-gray-4);
	}

	.meta {
		gap: 0.75rem 3rem;
		justify-content: space-between;
		flex-wrap: wrap;
		margin-top: 3rem;
		font-size: var(--sl-text-sm);
		color: var(--sl-color-gray-3);
	}
	.meta > :global(p:only-child) {
		margin-inline-start: auto;
	}

	.meta a {
		color: var(--sl-color-gray-3);
		text-decoration: underline;
	}
	.meta a:hover {
		color: var(--sl-color-white);
	}

	.site-footer {
		text-align: center;
		margin-top: 1rem;
		padding-top: 1rem;
		border-top: 1px solid var(--sl-color-gray-5);
	}

	.kudos {
		display: inline-flex;
		align-items: center;
		gap: 0.5em;
		margin-bottom: 0.5rem;
		font-size: var(--sl-text-xs);
		text-decoration: none;
		color: var(--sl-color-gray-3);
	}
	.kudos:hover {
		color: var(--sl-color-white);
	}
	.kudos :global(svg) {
		color: var(--sl-color-orange);
	}

	.copyright {
		font-size: var(--sl-text-xs);
		color: var(--sl-color-gray-3);
		margin: 0;
	}
	.copyright a {
		color: var(--sl-color-gray-3);
		text-decoration: underline;
	}
	.copyright a:hover {
		color: var(--sl-color-white);
	}

	.links {
		font-size: var(--sl-text-xs);
		color: var(--sl-color-gray-3);
		margin: 0.25rem 0 0;
	}
	.links a {
		color: var(--sl-color-gray-3);
		text-decoration: underline;
	}
	.links a:hover {
		color: var(--sl-color-white);
	}
</style>
